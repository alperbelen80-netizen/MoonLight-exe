# MoonLight Backend Configuration

# Backend HTTP port
PORT=8001

# Redis connection
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# SQLite database path
DB_PATH=../data/db/moonlight.sqlite

# Data storage directory
DATA_DIR=../data

# ART Signing Secret (HMAC-SHA256)
ART_SIGNING_SECRET=change_me_production_secret_key_min_32_chars

# Logging level
LOG_LEVEL=info

# Node environment
NODE_ENV=development

# Timezone (UTC enforcement)
TZ=UTC

# Demo mode (FakeBroker only)
FAKE_BROKER_ONLY=true

# CORS origin for desktop app
DESKTOP_APP_ORIGIN=http://localhost:5173
