{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "tsconfig.json",
    "assets": [
      { "include": "indicators/templates/**/*.json", "outDir": "dist/backend/src" },
      { "include": "config/**/*.yaml", "outDir": "dist/backend/src" }
    ],
    "watchAssets": true
  }
}
