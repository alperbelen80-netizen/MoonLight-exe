{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "signal_id",
    "idempotency_key",
    "source",
    "symbol",
    "tf",
    "ts",
    "direction",
    "ev",
    "confidence_score",
    "valid_until",
    "latency_budget_ms",
    "schema_version",
    "environment"
  ],
  "properties": {
    "signal_id": {
      "type": "string",
      "pattern": "^SIG_"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "strategy_id": {
      "type": "string"
    },
    "symbol": {
      "type": "string",
      "pattern": "^[A-Z]{3,10}$"
    },
    "tf": {
      "type": "string",
      "enum": ["1s", "3s", "5s", "15s", "30s", "1m", "5m", "15m", "30m", "1h", "4h", "1d"]
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "direction": {
      "type": "string",
      "enum": ["CALL", "PUT"]
    },
    "ev": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "valid_until": {
      "type": "string",
      "format": "date-time"
    },
    "latency_budget_ms": {
      "type": "number",
      "minimum": 0
    },
    "uncertainty_level": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH"]
    },
    "requested_stake": {
      "type": "number",
      "minimum": 0
    },
    "schema_version": {
      "type": "number",
      "minimum": 1
    },
    "environment": {
      "type": "string",
      "enum": ["LIVE", "SANDBOX", "BACKTEST"]
    }
  },
  "additionalProperties": false
}
