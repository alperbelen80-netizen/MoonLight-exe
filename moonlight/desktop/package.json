{
  "name": "moonlight-desktop",
  "version": "1.0.0",
  "description": "MoonLight Owner Desktop Console",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "MOONLIGHT_SPAWN_BACKEND=true electron .",
    "build": "tsc && vite build && tsc main/index.ts main/backend-manager.ts --outDir dist-electron/main && tsc main/preload.ts --outDir dist-electron",
    "build:preload": "tsc main/preload.ts --outDir dist-electron",
    "preview": "vite preview",
    "dist": "yarn build && electron-builder",
    "dist:win": "yarn build && electron-builder --win --x64",
    "test": "vitest run"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.303.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "sonner": "^2.0.7",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "electron": "^28.1.4",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^1.2.0"
  },
  "build": {
    "productName": "MoonLight Owner Console",
    "appId": "com.moonlight.owner",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "dist-renderer/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist-bundle",
        "to": "backend-bundle",
        "filter": [
          "**/*",
          "!**/*.map"
        ]
      },
      {
        "from": "../backend/node_modules",
        "to": "backend-bundle/node_modules",
        "filter": [
          "**/*",
          "!**/*.md",
          "!**/*.ts",
          "!**/test/**",
          "!**/tests/**",
          "!**/*.d.ts.map",
          "!**/docs/**"
        ]
      },
      {
        "from": "../backend/.env.example",
        "to": "backend-bundle/.env.example"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MoonLight Owner Console"
    }
  }
}
